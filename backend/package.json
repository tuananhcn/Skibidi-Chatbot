{
  "name": "jawuan-gpt-api",
  "version": "1.0.0",
  "type": "module",
  "author": "Jawuan Lewis",
  "license": "MIT",
  "description": "API for interacting with OpenAI's GPT models",
  "main": "dist/app.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "concurrently \"tsc --watch\" \"nodemon dist/app.js\"",
    "format": "prettier --write .",
    "lint": "prettier --check ."
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "mongoose": "^9.2.4",
    "nanoid": "^5.1.6",
    "openai": "^6.27.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^25.3.5",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "prettier": {
    "semi": true,
    "tabWidth": 2,
    "singleQuote": true,
    "jsxSingleQuote": false,
    "trailingComma": "es5"
  }
}
